{
  // Prisma extension settings
  "prisma.fileWatcher": true,
  "prisma.showPrismaDataPlatformNotification": false,
  // Use Prisma ORM 7 language server (not pinned to v6 diagnostics/formatting)
  "prisma.pinToPrisma6": false,
  
  // File associations
  "files.associations": {
    "*.prisma": "prisma"
  },
  
  // Language-specific settings
  "[prisma]": {
    "editor.defaultFormatter": "Prisma.prisma",
    "editor.formatOnSave": true,
    "editor.quickSuggestions": {
      "strings": true
    }
  },
  
  // Schema path for generate / language server (official key: prisma.schemaPath)
  "prisma.schemaPath": "${workspaceFolder}/prisma/schema.prisma"
}

