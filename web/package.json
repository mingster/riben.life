  "name": "riben.life.",
  "version": "2026.4.20",
  "private": true,
  "scripts": {
    "install:platform": "bun run bin/install.ts",
    "dev": "next dev -p 3001",
    "debugdev": "bun run postinstall; NODE_OPTIONS='--inspect' next dev -p 3001",
    "build": "bun run postinstall; next build",
    "build:production": "node bin/optimize-build.js",
    "start": "next start -p 3001",
    "format": "npx biome format --write ./src",
    "postinstall": "bun run sql:generate && node scripts/patch-three-clock.js",
    "patch:three-clock": "node scripts/patch-three-clock.js",
    "dbpush": "bun run sql:dbpush",
    "sql:generate": "bunx prisma generate",
    "sql:dbpush": "bunx prisma db push",
    "install:check": "bun run bin/install.ts --check",
    "install:wipeout": "bun run bin/install.ts --wipeout",
    "validate:aws-s3": "bun --env-file=.env.local run bin/validate-aws-s3-credentials.ts",
    "db:close-connections": "bun run bin/close-db-connections.ts",
    "generate:favicons": "bun run scripts/generate-favicons.ts",
    "fix:bag-glb-names": "bun run bin/fix-bag-glb-names.ts",
    "depcheck": "npx depcheck .",
    "precommit": "lint-staged",
    "commit": "clear && npx git-cz",
    "lint": "next lint; eslint --fix \"./src/**/*.{js,jsx,ts,tsx}\"",
    "bio_lint": "npx biome check --fix ./src",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "link:agents-skills": "bash bin/link-user-agents-skills.sh"
  },
